{
    "name": "stumed/my-admin",
    "description": "Laravel 后台管理基础包，提供用户、角色、权限、部门、菜单、文件管理等核心功能",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "admin", "rbac", "permission", "management"],
    "authors": [
        {
            "name": "StuMed",
            "email": "stumed@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "laravel/sanctum": "^4.0",
        "spatie/laravel-permission": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "StuMed\\MyAdmin\\": "src/",
            "StuMed\\MyAdmin\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "StuMed\\MyAdmin\\MyAdminServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
